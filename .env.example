# Auth API Configuration — targets the public-facing port (8081) of maintainerd-auth
VITE_AUTH_API_BASE_URL=http://api.maintainerd.auth:8081/api/v1

# -----------------------------------------------------------
# Backend CORS Configuration (maintainerd-auth .env)
# -----------------------------------------------------------
# Add this origin to the backend's allowed origins so cookies
# and cross-origin requests from this app work in production:
#
#   CORS_ALLOWED_ORIGINS=...,http://localhost:5174,...
#
# In development, the Vite proxy handles all /api/* traffic
# locally, so CORS is not an issue.
# -----------------------------------------------------------

# Dev server port — keep 5174 to avoid conflicting with the
# admin console (which uses 5173).
# VITE_DEV_PORT=5174

# Other environment variables can be added here
# VITE_APP_NAME=Maintainerd Auth Identity
# VITE_APP_VERSION=1.0.0
